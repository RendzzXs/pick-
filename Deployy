# Create server.js (BACKEND)
echo -e "${YELLOW}[6/8]📝 Creating server.js...${NC}"
cat > server.js << 'EOF'
const express = require('express');
const cors = require('cors');
const axios = require('axios');
const path = require('path');
const app = express();
const port = 3000;

// Middleware
app.use(cors());
app.use(express.json());
app.use(express.static('public'));

// Logging
app.use((req, res, next) => {
    console.log(`[${new Date().toISOString()}] ${req.method} ${req.url}`);
    next();
});

// API Reset Password
app.post('/api/reset-password', async (req, res) => {
    try {
        const { domain, plta, userId, newPassword } = req.body;
        
        console.log(`\n🔐 RESET PASSWORD REQUEST:`);
        console.log(`   Domain: ${domain}`);
        console.log(`   User ID: ${userId}`);
        
        // Bersihkan domain
        const cleanDomain = domain.trim().endsWith('/') ? domain.trim().slice(0, -1) : domain.trim();
        
        // Validasi URL
        try {
            new URL(cleanDomain);
        } catch {
            return res.status(400).json({
                success: false,
                error: 'Format domain tidak valid!'
            });
        }

        // Headers untuk Pterodactyl API
        const headers = {
            'Authorization': `Bearer ${plta}`,
            'Content-Type': 'application/json',
            'Accept': 'Application/vnd.pterodactyl.v1+json',
        };

        console.log('📡 Fetching user data...');
        
        // STEP 1: Ambil data user
        const userResponse = await axios.get(`${cleanDomain}/api/application/users/${userId}`, { 
            headers,
            timeout: 10000 
        });
        
        const userData = userResponse.data.attributes;
        console.log(`✅ User ditemukan: ${userData.username}`);

        // STEP 2: Update password
        console.log('📡 Updating password...');
        const updateResponse = await axios.patch(`${cleanDomain}/api/application/users/${userId}`, {
            email: userData.email,
            username: userData.username,
            first_name: userData.first_name,
            last_name: userData.last_name,
            password: newPassword
        }, { 
            headers,
            timeout: 10000 
        });

        console.log('✅ Password updated successfully!');
        
        res.json({
            success: true,
            data: {
                username: updateResponse.data.attributes.username,
                email: updateResponse.data.attributes.email,
                first_name: updateResponse.data.attributes.first_name,
                last_name: updateResponse.data.attributes.last_name,
                id: updateResponse.data.attributes.id
            }
        });

    } catch (error) {
        console.error('❌ Error:', error.message);
        
        let errorMessage = 'Unknown error';
        if (error.response) {
            errorMessage = error.response.data?.errors?.[0]?.detail || error.message;
        } else {
            errorMessage = error.message;
        }
        
        res.status(500).json({
            success: false,
            error: errorMessage
        });
    }
});

// Test endpoint
app.get('/api/test', (req, res) => {
    res.json({ success: true, status: 'Server is running!' });
});

// Serve HTML
app.get('/', (req, res) => {
    res.sendFile(path.join(__dirname, 'public', 'index.html'));
});

app.listen(port, '0.0.0.0', () => {
    console.log(`\n🚀 Server running at:`);
    console.log(`   http://localhost:${port}`);
    console.log(`   http://rendzz-panelku.biz.id:${port}`);
});
EOF

